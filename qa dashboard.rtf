\
  <!-- ALERTS VIEW -->\
\
  <div class="view" id="view-alerts">\
    <div class="alert-section">\
      <div class="alert-section-title">\
        \uc0\u55357 \u56628  Gecikmi\u351  G\'f6revler\
        <span class="alert-count" id="overdueCount">0</span>\
      </div>\
      <div id="overdueAlerts"></div>\
    </div>\
    <div class="alert-section">\
      <div class="alert-section-title">\
        \uc0\u55357 \u57313  Bug\'fcn Biten\
        <span class="alert-count warn" id="todayCount">0</span>\
      </div>\
      <div id="todayAlerts"></div>\
    </div>\
    <div class="alert-section">\
      <div class="alert-section-title">\
        \uc0\u55357 \u57315  3 G\'fcn \u304 \'e7inde Bitiyor\
        <span class="alert-count info" id="soonCount">0</span>\
      </div>\
      <div id="soonAlerts"></div>\
    </div>\
