\
</div>\
\
<!-- MODAL -->\
\
<div class="modal-overlay" id="modalOverlay" onclick="closeModalIfOutside(event)">\
  <div class="modal" id="modalBox">\
    <h2 id="modalTitle">\uc0\u10133  Yeni G\'f6rev Olu\u351 tur</h2>\
    <div class="form-group">\
      <label>G\'f6rev Ba\uc0\u351 l\u305 \u287 \u305  *</label>\
      <input type="text" id="taskTitle" placeholder="G\'f6rev ba\uc0\u351 l\u305 \u287 \u305 n\u305  girin...">\
    </div>\
    <div class="form-group">\
      <label>A\'e7\uc0\u305 klama</label>\
      <textarea id="taskDesc" placeholder="G\'f6rev a\'e7\uc0\u305 klamas\u305 ..."></textarea>\
    </div>\
    <div class="form-row">\
      <div class="form-group">\
        <label>Tak\uc0\u305 m Lideri *</label>\
